# Frontend - Email API endpoint (relative path)
VITE_EMAIL_ENDPOINT=/api/send-email

# Frontend - Email recipient address
VITE_EMAIL_TO=info@axsel.africa

# Backend - Resend API configuration
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_EMAIL_TO=info@yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
