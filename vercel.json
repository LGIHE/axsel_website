{
  "version": 2,
  "buildCommand": "npm run build",
  "env": {
    "RESEND_API_KEY": "@resend_api_key",
    "RESEND_FROM_EMAIL": "@resend_from_email",
    "RESEND_EMAIL_TO": "@resend_email_to",
    "VITE_EMAIL_TO": "@vite_email_to"
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/strategy",
      "destination": "/api/strategy"
    },
    {
      "source": "/api/send-email",
      "destination": "/api/send-email"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
